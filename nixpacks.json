{
  "providers": {
    "node": {
      "version": "24.13.0"
    }
  },
  "variables": {
    "NPM_CONFIG_REGISTRY": "https://registry.npmmirror.com",
    "npm_config_registry": "https://registry.npmmirror.com",
    "COREPACK_NPM_REGISTRY": "https://registry.npmmirror.com",
    "NEXT_PUBLIC_SITE_DOMAIN": "dai-shi.cn"
  },
  "phases": {
    "install": {
      "cmds": [
        "npm config set registry https://registry.npmmirror.com",
        "NPM_CONFIG_REGISTRY=https://registry.npmmirror.com npm_config_registry=https://registry.npmmirror.com COREPACK_NPM_REGISTRY=https://registry.npmmirror.com corepack enable",
        "NPM_CONFIG_REGISTRY=https://registry.npmmirror.com npm_config_registry=https://registry.npmmirror.com COREPACK_NPM_REGISTRY=https://registry.npmmirror.com corepack prepare pnpm@10.21.0 --activate",
        "pnpm config set registry https://registry.npmmirror.com",
        "NPM_CONFIG_REGISTRY=https://registry.npmmirror.com npm_config_registry=https://registry.npmmirror.com COREPACK_NPM_REGISTRY=https://registry.npmmirror.com pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "cmds": ["pnpm run build"]
    }
  },
  "start": {
    "cmd": "pnpm run start"
  }
}
